# Root environment for the API and worker.
# Do not set APP_NAME here because both services currently read the same file.

# API
WORKER_URL=http://127.0.0.1:8001
REQUEST_TIMEOUT_SECONDS=180
OPTIMIZE_LOGS_DIR=data/run_logs
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001

# OpenAI
USE_MOCK_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_FALLBACK_MODEL=gpt-5.1
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_REASONING_EFFORT=none
OPENAI_MAX_RETRIES=2

# Worker / TribeV2
TRIBE_REPO_PATH=<path-to-your-tribev2-clone>
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_CACHE_FOLDER=/tmp/tribe_cache
TRIBE_DEVICE=cuda
WORKER_MAX_BATCH_SIZE=16

# Hugging Face
HF_TOKEN=
